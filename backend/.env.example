# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

SECRET_KEY=django-insecure-dev-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,.railway.app

# PostgreSQL — replace with your local credentials or Railway's DATABASE_URL
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/breathe_esg

# CORS — comma-separated origins (set to your Vercel URL in production)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
